# Copy this file to backend/.env and fill in real values before running.

# Django secret key (generate a new one for production)
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts (e.g. 127.0.0.1,localhost)
ALLOWED_HOSTS=127.0.0.1,localhost

# Email backend settings (needed for OTP delivery)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# Database (leave empty to use default SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/event_management
